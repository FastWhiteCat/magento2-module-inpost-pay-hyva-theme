{
    "name": "inpost/magento2-module-inpost-pay-hyva-theme",
    "description": "Module integrates InPost Pay Mobile application with Magento store. Implementation for Hyva Theme",
    "type": "magento2-module",
    "license": ["CC-BY-NC-ND-4.0"],
    "require": {
        "php": ">=8.1",
        "laminas/laminas-http": "*",
        "monolog/monolog": "*",
        "psr/log": "*",
        "guzzlehttp/guzzle": "*",
        "inpost/magento2-module-inpost-pay": ">=2.4.0",
        "inpost/magento2-module-restrictions": ">=2.1.0",
        "hyva-themes/magento2-default-theme": "*"
    },
    "autoload": {
        "files": [
            "src/registration.php"
        ],
        "psr-4": {
            "InPost\\InPostPayHyvaTheme\\": "src"
        }
    },
    "keywords": [
        "magento2",
        "inpostpay",
        "hyva"
    ]
}
